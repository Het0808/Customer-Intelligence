# ─────────────────────────────────────────────────────────────────────────────
# Customer Intelligence Platform — Environment Template
# cp .env.example .env   then fill in your values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Data paths ───────────────────────────────────────────────────────────────
# Root of all data artefacts (raw, processed, samples).
# Relative paths are resolved from the project root.
DATA_DIR=data

# Override individual subdirs if you mount separate volumes:
# RAW_DATA_DIR=data/raw
# PROCESSED_DATA_DIR=data/processed
# SAMPLES_DATA_DIR=data/samples

# ── Ingestion ────────────────────────────────────────────────────────────────
# Number of CFPB complaint records to download (API max ~10 000 per call)
CFPB_SAMPLE_SIZE=10000

# Override source URLs if behind a proxy or using a cached mirror:
# UCI_BANK_URL=https://archive.ics.uci.edu/ml/machine-learning-databases/00222/bank-additional.zip
# CFPB_API_URL=https://api.consumerfinance.gov/data/complaints.json

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=customer-intelligence

# ── Model serving ────────────────────────────────────────────────────────────
MODEL_REGISTRY_URI=models:/bank-campaign-conversion/Production
API_HOST=0.0.0.0
API_PORT=8000

# ── RAG / LLM ────────────────────────────────────────────────────────────────
# Leave blank to use only local/open-source models.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# HuggingFace sentence-transformer used for FAISS indexing
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Monitoring ───────────────────────────────────────────────────────────────
EVIDENTLY_REFERENCE_DATASET=data/processed/bank_marketing_reference.parquet
