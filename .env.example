# ─────────────────────────────────────────────────────────────────────────────
# Customer Intelligence Platform — Environment Template
# cp .env.example .env   then fill in your values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Data paths ───────────────────────────────────────────────────────────────
# Root of all data artefacts (raw, processed, samples).
# Relative paths are resolved from the project root.
DATA_DIR=data

# Override individual subdirs if you mount separate volumes:
# RAW_DATA_DIR=data/raw
# PROCESSED_DATA_DIR=data/processed
# SAMPLES_DATA_DIR=data/samples

# ── Ingestion ────────────────────────────────────────────────────────────────
# Number of CFPB complaint records to download (API max ~10 000 per call)
CFPB_SAMPLE_SIZE=10000

# Override source URLs if behind a proxy or using a cached mirror:
# UCI_BANK_URL=https://archive.ics.uci.edu/ml/machine-learning-databases/00222/bank-additional.zip
# CFPB_API_URL=https://api.consumerfinance.gov/data/complaints.json

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=customer-intelligence

# ── Model serving ────────────────────────────────────────────────────────────
MODEL_REGISTRY_URI=models:/bank-campaign-conversion/Production
API_HOST=0.0.0.0
API_PORT=8000

# ── RAG / LLM ────────────────────────────────────────────────────────────────
# LLM provider: "openai" (default) or "ollama" (local, free)
LLM_PROVIDER=openai

# Model name -- used for the selected provider
# OpenAI examples : gpt-4o-mini, gpt-4o
# Ollama examples : llama3.2, mistral, phi3
LLM_MODEL=gpt-4o-mini

# For Ollama or other OpenAI-compatible endpoints:
# LLM_BASE_URL=http://localhost:11434/v1

# Seconds to wait for an LLM response before timing out
LLM_TIMEOUT=30

# Max tokens in LLM response
LLM_MAX_TOKENS=512

# Leave blank if using Ollama (no key needed)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Retrieval score below which a query is refused (range 0-1, default 0.35)
RAG_MIN_SCORE=0.35

# Path to the built FAISS index directory (relative to project root)
FAISS_INDEX_DIR=faiss_index

# sentence-transformer model for FAISS embedding (must match the one used at index time)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Monitoring ───────────────────────────────────────────────────────────────
EVIDENTLY_REFERENCE_DATASET=data/processed/bank_marketing_reference.parquet
